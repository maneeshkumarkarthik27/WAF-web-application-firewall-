WAF_APP_NAME=Automated WAF
WAF_ENV=development
WAF_UPSTREAM_URL=http://127.0.0.1:8001
WAF_DATABASE_URL=sqlite:///./data/waf.db
WAF_LOG_LEVEL=INFO
WAF_BLOCK_THRESHOLD=70
WAF_TEMP_BLOCK_SECONDS=900
WAF_OFFENDER_WARNING_THRESHOLD=2
WAF_OFFENDER_TEMP_BLOCK_THRESHOLD=3
WAF_OFFENDER_PERMANENT_BLOCK_THRESHOLD=5
WAF_RATE_LIMIT_REQUESTS=60
WAF_RATE_LIMIT_WINDOW_SECONDS=60
WAF_USER_AGENT_BLOCKLIST=sqlmap,nikto,acunetix,netsparker
WAF_MAX_BODY_BYTES=65536
WAF_PROTECTED_HOST=protected.local
WAF_ENABLE_IPTABLES=false
WAF_ENABLE_NFTABLES=false
